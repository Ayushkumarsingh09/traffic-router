# Production checklist (auto-applied on Vercel via env vars)

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/traffic_router?sslmode=require"
JWT_SECRET="generate-a-64-char-random-string"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="generate-a-strong-password"
GEOIP_API_URL="https://ip-api.com/json"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NODE_ENV="production"
RUN_SEED="true"
SEED_RULES="true"
